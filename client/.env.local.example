# ── Browser API URL ──────────────────────────────────────────────────────────
# Leave EMPTY to use the built-in Next.js proxy (recommended, no CORS issues).
# The proxy forwards /api/* → API_SERVER_URL automatically.
NEXT_PUBLIC_API_URL=

# ── Server-side proxy target ──────────────────────────────────────────────────
# Where Next.js should forward proxied API requests (server-to-server, no CORS).
# Always use localhost here since both services run on the same machine.
API_SERVER_URL=http://localhost:3001
